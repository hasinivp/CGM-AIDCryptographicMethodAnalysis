from sensor import Sensor
from insulin_pump import InsulinPump
from communication_channel import CommunicationChannel
import time
import csv
import statistics
import pandas as pd
import tracemalloc 

def measure_computation(func, *args, **kwargs):
    start = time.perf_counter()
    tracemalloc.start()
    result  = func(*args, **kwargs)
    end = time.perf_counter()
    current, peak = tracemalloc.get_traced_memory()
    elapsed = end-start
    return result, elapsed, peak

def store_stats(data, enc_type):
    mean_val = statistics.mean(data)
    median_val = statistics.median(data)
    df = pd.DataFrame({ #generated by Gemini
        'Encryption_Type':enc_type,
        'Raw_Data': data,
        'Mean': [mean_val] * len(data),
        'Median': [median_val] * len(data),
         })
    return df

def store_summary(enc_times, dec_times, enc_memory, dec_memory,  key_exchange, enc_type):
    mean_enc = statistics.mean(enc_times)
    mean_dec = statistics.mean(dec_times)
    mean_enc_memory = statistics.mean(enc_memory)
    mean_dec_memory = statistics.mean(dec_memory)
    df = pd.DataFrame({
        'Encryption_Algorithm': [enc_type],
        'Key_Exchange_Time': [key_exchange],
        'Average_Encryption_Time': [mean_enc],
        'Average_Decryption_Time': [mean_dec],
        'Average_Peak_Encryption_Memory': [mean_enc_memory],
        'Average_Peak_Decryotion_Memory': [mean_dec_memory]
    })
    return df

def aes_key_exchange(channel, test_sensor, test_insulin, key_len):
     #send cgm public key
    channel.send(test_sensor.return_public_key())
    test_insulin.key_exchange(channel.receive(), key_len)

    #sent aid public key
    channel.send(test_insulin.return_public_key())
    test_sensor.key_exchange((channel.receive()), key_len)

def full_session(enc_func, dec_func, key_len, final_dataset_collection, algo_name):
    test_sensor = Sensor(json_filepath = "sample_messages.json")
    test_insulin = InsulinPump()
    channel = CommunicationChannel()
    encryption_times = []
    decryption_times = []
    enc_memory = []
    dec_memory = []
    
    _, key_exchange_time, key_exchange_memory  = measure_computation(aes_key_exchange,channel, test_sensor, test_insulin, key_len)
    
    print("Succesful key exchange")

    encryption = getattr(test_sensor, enc_func)
    decryption = getattr(test_insulin, dec_func)

    for i in range (1000):
        crypto_output, enc_time, encryption_memory = measure_computation(encryption)
        ct, nonce = crypto_output
        encryption_times.append(enc_time)
        enc_memory.append(encryption_memory)
        channel.send([ct, nonce])
        received_packet = channel.receive()
        plaintext, dec_time, decryption_memory = measure_computation(decryption, received_packet[0], received_packet[1])
        decryption_times.append(dec_time)
        dec_memory.append(decryption_memory)
        print("Decryption complete!")
        print(plaintext)

   # df = store_stats(encryption_times, 'AES_GCM')
   # df.to_csv('encrypt_latency_data.csv', index=False)
   # df = store_stats(decryption_times, 'AES_GCM')
   # df.to_csv('decrypt_latency_data.csv', index=False)

    df = store_summary(encryption_times, decryption_times, enc_memory, dec_memory, key_exchange_time, algo_name)
    final_dataset_collection.append(df)
    

def main():
    final_dataset_collection = []
    full_session("aes_encryption", "decrypt_aes", 16, final_dataset_collection, "AES_GCM_128")
    full_session("aes_encryption", "decrypt_aes", 32, final_dataset_collection, "AES_GCM_256")
    df_final = pd.concat(final_dataset_collection, ignore_index = True)
    df_final.to_csv('results.csv' ,index=False)
    
if __name__ == "__main__":
    main()
